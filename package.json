{
  "name": "lumi-addons",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "license": "GPL-3.0",
  "description": "First-party dynamic addons for the Lumi Discord bot. Not a package — each directory is installed individually by Lumi's downloader.",
  "imports": {
    "#lib/commands.js": "./.lumi/packages/core/src/lib/commands.ts",
    "#lib/env.js": "./.lumi/packages/core/src/lib/env.ts",
    "#lib/permissions.js": "./.lumi/packages/core/src/lib/permissions/index.ts",
    "#lib/module-system.js": "./.lumi/packages/core/src/lib/module-system/Module.ts",
    "#lib/rabbit.js": "./.lumi/packages/core/src/lib/rabbitmq/index.ts",
    "#lib/types.js": "./.lumi/packages/core/src/lib/types/common.ts",
    "#lib/guild-transaction.js": "./.lumi/packages/core/src/lib/guild-transaction.ts",
    "#lib/module-check.js": "./.lumi/packages/core/src/lib/module-check.ts",
    "#lib/scheduler-bus.js": "./.lumi/packages/core/src/lib/scheduler-bus.ts",
    "#lib/schedule-task.js": "./.lumi/packages/core/src/lib/schedule-task.ts",
    "#database/*.js": "./.lumi/packages/core/src/lib/database/*.ts",
    "#utilities/*.js": "./.lumi/packages/core/src/lib/utilities/*.ts",
    "#core/lib/*.js": "./.lumi/packages/core/src/lib/*.ts",
    "#core/module-system/*.js": "./.lumi/packages/core/src/lib/module-system/*.ts",
    "#core/*.js": "./.lumi/packages/core/src/lib/*.ts",
    "#root/*.js": "./.lumi/packages/core/src/*.ts",
    "#modules/*.js": "./.lumi/packages/core/src/modules/*.ts"
  },
  "scripts": {
    "setup": "sh scripts/setup.sh",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint . --ext ts"
  }
}
